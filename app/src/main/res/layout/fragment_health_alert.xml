<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Normal content -->
    <ScrollView
        android:id="@+id/scrollNormal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/danger_signs_label"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <CheckBox android:id="@+id/cbSwelling"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_swelling" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbHeadache"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_headache" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbVision"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_vision" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbAbdominal"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_abdominal" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbBleeding"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_bleeding" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbFever"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_fever" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />

                    <CheckBox android:id="@+id/cbNoMovement"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="@string/sign_no_movement" android:textSize="18sp"
                        android:minHeight="56dp" android:buttonTint="@color/error"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <!-- FULL SCREEN RED ALERT (hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutRedAlert"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/red_alert"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="80sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/emergency_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:lineSpacingMultiplier="1.3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/emergency_helpline"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:lineSpacingMultiplier="1.3" />

        <Button
            android:id="@+id/btnCall104"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/call_104"
            android:textSize="24sp"
            android:textStyle="bold"
            android:backgroundTint="@color/white"
            android:textColor="@color/red_alert"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnDismissAlert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/clear_all"
            android:textSize="20sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/white" />
    </LinearLayout>
</FrameLayout>
